# Project-local machine configuration for ORBIT
# Copy to .env.local and edit as needed.
# The interactive bootstrap helper (./scripts/bootstrap.sh obsidian) also writes here.

# Optional: enables Obsidian MCP capability/background activation when set.
export ORBIT_OBSIDIAN_VAULT_ROOT="/Volumes/2TB/MAS/vio_vault"
export ORBIT_ENABLE_KNOWLEDGE=1
